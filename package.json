{
  "name": "masters-planning",
  "private": true,
  "version": "1.0.0",
  "description": "Cloudflare Pages + D1 application planner.",
  "scripts": {
    "data:extract": "python3 tools/extract_workbook.py",
    "build": "node tools/build_static.mjs",
    "db:seed-file": "python3 tools/build_seed_sql.py",
    "db:create": "wrangler d1 create masters-planning",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=seed.sql",
    "db:seed:remote": "wrangler d1 execute DB --remote --file=seed.sql",
    "dev": "npm run build && wrangler pages dev dist",
    "deploy": "git push"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
